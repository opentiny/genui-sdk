{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@opentiny/genui-sdk-vue": [
        "../../../packages/frameworks/vue/src/index.ts"
      ],
      "@opentiny/genui-sdk-core": [
        "../../../packages/core/src/index.ts"
      ],
      "@opentiny/tiny-schema-renderer": [
        "../../../projects/tiny-schema-renderer/index.js"
      ],
      "schema-renderer-ng-adpater": [
        "../schema-renderer-ng-adpater/src/index.ts"
      ],
      "@opentiny/genui-sdk-materials-vue-opentiny-vue": [
        "../../../packages/materials/vue-opentiny-vue/src/index.ts"
      ],
      "@opentiny/genui-sdk-materials-vue-opentiny-vue/*": [
        "../../../packages/materials/vue-opentiny-vue/src/*"
      ],
      "@opentiny/genui-sdk-materials-angular-opentiny-ng": [
        "../../../packages/materials/angular-opentiny-ng/src/index.ts"
      ]
    }
  },
  "include": [
    "src/**/*",
    "../**/*",
    "../../../packages/**/*",
    "../../../projects/**/*"
  ]
}
