{
  "name": "genui-sdk",
  "version": "1.0.0",
  "description": "OpenTiny GenUI SDK",
  "main": "index.js",
  "scripts": {
    "dev": "pnpm --filter genui-sdk-playground dev",
    "dev:docs": "pnpm --filter genui-sdk-docs dev",
    "dev:homepage": "pnpm --filter genui-sdk-homepage-web dev",
    "build:projects": "pnpm --filter @opentiny/tiny-schema-renderer build && pnpm --filter @opentiny/tiny-schema-renderer-ng build",
    "build:materials": "pnpm --filter @opentiny/genui-sdk-materials-* build",
    "prebuild:lib": "pnpm build:materials",
    "build:lib": "pnpm --filter @opentiny/genui-sdk-core build && pnpm --filter @opentiny/genui-sdk-vue build && pnpm --filter @opentiny/genui-sdk-angular build:lib",
    "build:plugins": "pnpm --filter vite-commit-hash-plugin build",
    "dev:server": "pnpm --filter @opentiny/genui-sdk-server dev",
    "build:server": "pnpm --filter @opentiny/genui-sdk-server build",
    "prebuild:playground": "pnpm build:projects && pnpm build:lib && pnpm build:plugins && pnpm --filter schema-renderer-ng-adpater build && pnpm --filter @opentiny/genui-sdk-chat-completions build",
    "build:playground": "pnpm --filter genui-sdk-playground build",
    "build:playground-web": "pnpm prebuild:playground && pnpm --filter genui-sdk-playground-web build",
    "build:homepage": "pnpm --filter genui-sdk-homepage-web build",
    "build:docs": "pnpm --filter genui-sdk-docs build",
    "build": "pnpm build:playground"
  },
  "pnpm": {
    "patchedDependencies": {
      "ai@6.0.116": "patches/ai@6.0.116.patch"
    }
  },
  "keywords": [],
  "author": "OpenTiny",
  "packageManager": "pnpm@10.12.1",
  "devDependencies": {
    "@babel/parser": "^7.28.3"
  }
}
