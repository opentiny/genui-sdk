{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "es2020",
      "DOM"
    ],
    "module": "ESNext",
    "outDir": "./dist",
    "strict": true,
    "sourceMap": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "typeRoots": [
      "./node_modules/@types"
    ]
  },
  "include": [
    "./src",
    "./src/*.d.ts",
    "./deprecated/extract-schema-json.ts"
  ]
}
