{
  "compilerOptions": {
    "baseUrl": "./",
    "target": "ES2020",
    "lib": [
      "es2020",
      "DOM"
    ],
    "module": "ESNext",
    "outDir": "./dist",
    "strict": false,
    "sourceMap": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "typeRoots": [
      "./node_modules/@types"
    ]
  },
  "include": [
    "../../src/vue/**/*"
  ],
  "files": [
    "../../src/vue/index.ts"
  ]
}
