# 模型名（与 DeepSeek / OpenAI 兼容网关一致；单模型时用）
BENCH_MODEL=gpt-4o-mini
DEEPSEEK_API_KEY=W7owamZlP-AmFqY32UOagnd5_mdI-yc7AqDZjtUCze8QLGcBFZ1Pcz0Re3igX7UMsWCSC1AWftwb8C-qLgGGiQ
DEEPSEEK_BASE_URL=https://api.modelarts-maas.com/v1/

# 可选：多模型对比（逗号分隔，会逐模型生成样本并在报告中并排对比）
# 设置后优先生成列表中的模型；BENCH_MODEL 仍可作为配置主键/报告兜底显示
# BENCH_MODELS=deepseek-chat,deepseek-reasoner

# 框架：Vue | Angular（也可在 src/benchmark.config.ts 中写死）
# BENCH_FRAMEWORK=Vue

# 可选：只跑某个内置 sample id（与 src/samples 中 case id 一致）
# BENCH_SCENARIO=simple-form

# 可选：批量场景（逗号分隔），优先级高于 BENCH_SCENARIO
# BENCH_SCENARIOS=simple-form,table-crud

# 可选：每个场景重复执行次数（最小 1）
# BENCH_REPEAT=3

# 可选：true/false 或 1/0，是否在控制台额外输出 JSON 报告摘要
# BENCH_JSON=false

# 可选：样本 JSON 目录（默认包内 samples/）
# BENCH_SAMPLES_DIR=

# 可选：报告输出目录（默认 samples/reports/）
# BENCH_OUTPUT_DIR=

# DeepSeek API（生成样本阶段）
# DEEPSEEK_API_KEY=
